# --- secrets / local environment (never commit these) ---
.env
.env.*
*.key
secrets.*

# --- python ---
__pycache__/
*.pyc
.venv/
venv/
.mypy_cache/
.pytest_cache/

# --- editor / OS junk ---
.DS_Store
Thumbs.db
.vscode/
.idea/

# --- local test / preview artifacts (not part of the site) ---
.playwright-mcp/
# Dev/preview screenshots live at the repo root; the site's own images live under docs/.
/*.png

# --- experimental / dev-only, not wired into the live site (track when built) ---
# src/terms.py is the planned "Track B" discovery miner; the other two are one-off probes.
scripts/explore_signals.py
scripts/mine_test.py
src/terms.py

# --- local working notes (kept out of the public repo) ---
project/

# NOTE: data/ and docs/data/ are intentionally NOT ignored.
# Those committed files ARE the project's permanent longitudinal record.
# Exception: stray reference docs dropped into data/ are not part of that record.
data/*.pdf
